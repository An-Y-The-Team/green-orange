# Caddy automatically provisions + renews Let's Encrypt TLS for these domains.
# Domains/email come from the environment (set in .env.production), so there is
# nothing to edit in this file per-deployment.
{
	email {$ACME_EMAIL}
}

# Public marketing site
http://{$SITE_DOMAIN}:3000, http://www.{$SITE_DOMAIN}:3000 {
	reverse_proxy web:3000
}

# Payload CMS (admin + REST/GraphQL API)
http://{$CMS_DOMAIN}:3001 {
	# Allow media uploads through the admin panel.
	request_body {
		max_size 25MB
	}
	reverse_proxy cms:3001
}

# Authentik (identity provider) — OIDC login + admin UI for the CRM.
http://{$AUTH_DOMAIN}:9000 {
	reverse_proxy authentik-server:9000
}
