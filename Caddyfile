# Caddy automatically provisions + renews Let's Encrypt TLS for these domains.
# Domains/email come from the environment (set in .env.production), so there is
# nothing to edit in this file per-deployment.
{
	email {$ACME_EMAIL}
}

# Public marketing site
http://{$SITE_DOMAIN}:3000, http://www.{$SITE_DOMAIN}:3000 {
	log
	reverse_proxy web:3000
}

# Directus CMS (Studio + REST/GraphQL API). Edge port stays :3001 (external
# contract behind Pangolin); only the upstream container port changed to 8055.
http://{$CMS_DOMAIN}:3001 {
	log
	# Allow media uploads through the admin panel.
	request_body {
		max_size 25MB
	}
	reverse_proxy cms:8055
}

# CRM dashboard (Next.js). crm-api is NOT proxied here — it stays internal-only.
# Force X-Forwarded-Proto https: TLS terminates upstream at the Newt/Pangolin
# edge, so Caddy sees plain HTTP. Without this, Auth.js builds its OAuth callback
# (and cookies) for http://, and the Authentik redirect round-trip breaks.
http://{$CRM_DOMAIN}:3002 {
	log
	reverse_proxy crm-web:3002 {
		header_up X-Forwarded-Proto https
	}
}

# Authentik (identity provider) — OIDC login + admin UI for the CRM.
# TLS is terminated upstream at the Newt/Pangolin edge, which forwards plain
# HTTP here. Without this, Caddy advertises scheme=http to Authentik, so
# Authentik builds its CSP / redirect URLs for http:// — and the browser (on
# https://) then blocks the SPA's own API fetch ("interceptors" error). Force
# the real outside scheme so Authentik generates https:// URLs + CSP.
http://{$AUTH_DOMAIN}:9000 {
	log
	reverse_proxy authentik-server:9000 {
		header_up X-Forwarded-Proto https
	}
}

# Dozzle (real-time Docker log viewer).
# Fronted by Pangolin zero-trust network.
http://{$LOGS_DOMAIN}:8080 {
	log
	reverse_proxy dozzle:8080
}
