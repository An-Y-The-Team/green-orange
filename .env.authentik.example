# Copy to .env.authentik (gitignored) and fill in. Used only by
# docker-compose.authentik.yml.
#
#   cp .env.authentik.example .env.authentik
#   # generate the two secrets:
#   echo "PG_PASS=$(openssl rand -base64 36 | tr -d '\n')"          >> .env.authentik
#   echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 60 | tr -d '\n')" >> .env.authentik

# Connection to the SHARED Postgres from docker-compose.yml (which hosts the
# `authentik` database alongside `cms` and `crm`). These must match that
# container's credentials (POSTGRES_USER/PASSWORD = postgres/password in dev).
PG_HOST=postgres
PG_USER=postgres
PG_PASS=password
PG_DB=authentik

# Django secret key for Authentik. Generate with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=

# Image tag — pin to the current stable from https://goauthentik.io (releases).
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2025.10

# Host ports for the Authentik UI (defaults avoid the CRM's 3000-3002 / 5432 / 8000).
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

# First-boot bootstrap (dev convenience; applied only on a fresh DB volume).
# Lets you log in as akadmin immediately and script provider setup via the API.
# Generate the token: openssl rand -hex 32
AUTHENTIK_BOOTSTRAP_PASSWORD=akadmin-dev-change-me
AUTHENTIK_BOOTSTRAP_TOKEN=
AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@localhost
