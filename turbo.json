{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "cache": false,
      "dependsOn": ["^format"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "CRM_API_URL",
        "CRM_API_TOKEN",
        "DATABASE_URL",
        "AUTH_SECRET",
        "AUTH_AUTHENTIK_ID",
        "AUTH_AUTHENTIK_SECRET",
        "AUTH_AUTHENTIK_ISSUER"
      ]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "clean": {
      "cache": false
    }
  }
}
