# deploy/deploy.env — NON-SECRET config for the prod stack.
#
# Dockhand's git stack reads this as the compose env-file (envFilePath). Edit
# config here (on GitHub) or in Dockhand — for the same var, keep ONE home to
# avoid confusion (Dockhand's stored value overrides this file).
#
# SECRETS ARE NOT HERE. They live in Dockhand's secret store (injected via shell
# env at deploy time, never written to disk):
#   POSTGRES_PASSWORD, DIRECTUS_KEY, DIRECTUS_SECRET, DIRECTUS_ADMIN_PASSWORD,
#   DIRECTUS_STATIC_TOKEN, DIRECTUS_PREVIEW_SECRET, CRM_AUTH_SECRET,
#   CRM_OIDC_CLIENT_SECRET, AUTHENTIK_SECRET_KEY, AUTHENTIK_BOOTSTRAP_PASSWORD,
#   AUTHENTIK_BOOTSTRAP_TOKEN

# ── Container images — CI rewrites these three on each vX.Y.Z release ─────────
# (No CMS_IMAGE — the cms service pins directus/directus:12.0.2 directly in compose.)
WEB_IMAGE=ghcr.io/an-y-the-team/green-orange-web:v0.14.1
CRM_WEB_IMAGE=ghcr.io/an-y-the-team/green-orange-crm-web:v0.14.1
CRM_API_IMAGE=ghcr.io/an-y-the-team/green-orange-crm-api:v0.14.1
CRM_API_NEST_IMAGE=ghcr.io/an-y-the-team/green-orange-crm-api-nest:v0.14.1

# ── Postgres (non-secret parts; POSTGRES_PASSWORD is a secret in Dockhand) ────
POSTGRES_USER=postgres
POSTGRES_DB=cms

# ── Directus (KEY/SECRET/ADMIN_PASSWORD/STATIC_TOKEN/PREVIEW_SECRET are secrets)
DIRECTUS_DB_DATABASE=directus
DIRECTUS_PUBLIC_URL=https://cms.dichvuyan.com
DIRECTUS_ADMIN_EMAIL=haloany123@gmail.com
CORS_ORIGINS=https://dichvuyan.com,https://www.dichvuyan.com

# ── Caddy domains + TLS ───────────────────────────────────────────────────────
SITE_DOMAIN=dichvuyan.com
CMS_DOMAIN=cms.dichvuyan.com
CRM_DOMAIN=quanly.dichvuyan.com
AUTH_DOMAIN=auth.dichvuyan.com
ACME_EMAIL=ctydv.yan@gmail.com

# ── Authentik (SECRET_KEY / BOOTSTRAP_PASSWORD / BOOTSTRAP_TOKEN are secrets) ──
AUTHENTIK_TAG=2025.10
AUTHENTIK_BOOTSTRAP_EMAIL=admin@dichvuyan.com

# ── CRM OIDC — client_id is public by OAuth design; client_secret is a secret ─
CRM_OIDC_CLIENT_ID=p5KR2ljKHYdl7hmHC31nOFxQSkYejDyoeGZfYtXw 
