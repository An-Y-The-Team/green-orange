# crm-web environment.
#
# Leave CRM_API_URL UNSET to run the UI on built-in mock data (default for
# design work). Set it once the FastAPI backend (apps/crm-api) is running to
# switch every data fetch over to the real API — no UI code changes needed.
# It is server-only (never sent to the browser), so the backend can stay on an
# internal network with no public route.
#
# CRM_API_URL=http://localhost:8000
#
# crm-api endpoints are auth-protected. In local dev (AUTH_MODE=local) the web
# app auto-mints a bearer from /auth/token using CRM_DEV_USER/CRM_DEV_PASSWORD
# (default admin/admin) and re-mints on expiry — no manual token to keep fresh.
# Set CRM_API_TOKEN only to pin an explicit token (overrides the auto-mint):
# CRM_DEV_USER=admin
# CRM_DEV_PASSWORD=admin
# CRM_API_TOKEN=

# --- Authentik SSO (optional) -------------------------------------------------
# Leave these UNSET for local/mock dev — the dashboard stays open, no login.
# Set them to enable Auth.js login; the user's Authentik access token is then
# forwarded to crm-api (which must run with AUTH_MODE=oidc + matching OIDC_*).
# Get the values from: python3 scripts/setup-authentik-crm.py
#
# AUTH_SECRET=            # openssl rand -hex 32  (required when auth is enabled)
# AUTH_AUTHENTIK_ID=
# AUTH_AUTHENTIK_SECRET=
# AUTH_AUTHENTIK_ISSUER=http://localhost:9000/application/o/crm-dev/
