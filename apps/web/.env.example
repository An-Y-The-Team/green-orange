# Base URL of the decoupled Directus CMS that serves Services/Projects/Testimonials
# and accepts contact submissions. The browser loads media from /assets/<id> here,
# so it must be reachable from both the server (SSR/ISR) and the browser.
# Local dev: http://localhost:8055
NEXT_PUBLIC_CMS_URL=http://localhost:8055

# Public origin of this web app. Used for canonical URLs, Open Graph, sitemap.xml,
# robots.txt, and JSON-LD structured data. Defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server-only Directus credentials (NEVER prefix with NEXT_PUBLIC_) ───────
# Read-only static token used for SSR/ISR reads of published content.
# Created in the Directus Studio (migration Phase 3). Leave blank until then.
DIRECTUS_STATIC_TOKEN=

# Shared secret validated by the /api/preview route to enable draft preview.
# Must match DIRECTUS_PREVIEW_SECRET on the CMS side. Generate: openssl rand -hex 32
DIRECTUS_PREVIEW_SECRET=
