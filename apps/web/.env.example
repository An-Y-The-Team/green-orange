# Base URL of the decoupled Payload CMS that serves Services/Projects/Testimonials
# and accepts contact submissions. Must be reachable from both the server
# (build/SSR data fetch) and the browser (contact form POST), so it is public.
# Local dev defaults to http://localhost:3001 if unset.
NEXT_PUBLIC_CMS_URL=http://localhost:3001

# Public origin of this web app. Used for canonical URLs, Open Graph, sitemap.xml,
# robots.txt, and JSON-LD structured data. Defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
