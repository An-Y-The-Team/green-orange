# PostgreSQL connection string (read by payload.config.ts as process.env.DATABASE_URL)
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/cms
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public origin of the CMS. Used as Payload `serverURL` so uploaded media URLs are
# absolute. Defaults to http://localhost:3001 in local dev if unset.
CMS_PUBLIC_URL=http://localhost:3001
