# apps/cms is now config-as-code for Directus (schema snapshot + seed script).
# Directus itself runs from the official image and is configured via the compose
# files (local) or .env.production (prod) — NOT from this file.
#
# These vars are only read by the content seed script (seed/seed.ts), which logs
# in to a running Directus as admin and upserts content. Copy to `.env` to run it
# locally: cp .env.example .env

# Base URL of the running Directus instance to seed.
DIRECTUS_PUBLIC_URL=http://localhost:8055
# Admin credentials (match the running instance's bootstrap admin).
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin
