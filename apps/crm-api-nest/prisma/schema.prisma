// ── DRAFT v2 schema — NOT live ─────────────────────────────────────────────
// Implements docs/features/crm-database-schema.md (approved 2026-07-23).
// Prisma only reads schema.prisma, so this file is inert until we swap it in
// with a migration plan. Review here, then: rename → prisma migrate dev.
//
// Conventions carried over from v1 (see schema.prisma header):
//   • snake_case fields, emitted verbatim → responses need no mapping.
//   • Money is BigInt (integer VND), serialized to JSON number.
//   • Dates are @db.Date, serialized 'YYYY-MM-DD'.
//   • Enum-like fields are String, validated in DTOs. Values are ENGLISH
//     (language rule 2026-07-23); Vietnamese lives only in crm-web labels.ts.
//
// v2 changes vs v1:
//   • Real foreign keys everywhere (v1 linked via project_code strings).
//   • English enum values (v1 used Vietnamese snake_case).
//   • Dropped: Lead, Deal, Task (legacy pages, off nav), Cost (own module,
//     design pending), Acceptance (now project.acceptance_sub_status),
//     CrewMember.day_rate (no wage computation).
//   • Kept from v1 beyond the doc: Project.code (business ref on printables),
//     Quote.vat_rate (printable A4 shows VAT), ContractTemplate + the
//     Lexical body/template fields on Contract (printable contract feature).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int     @id @default(autoincrement())
  username        String  @unique
  hashed_password String
  full_name       String?
  disabled        Boolean @default(false)
}

model Client {
  id         Int      @id @default(autoincrement())
  name       String
  type       String // company | individual
  tax_code   String?
  note       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacts  Contact[]
  locations Location[]
  projects  Project[]
}

model Contact {
  id        Int     @id @default(autoincrement())
  client_id Int
  name      String
  phone     String? // also Zalo identity
  email     String?
  title     String?
  note      String?

  client             Client     @relation(fields: [client_id], references: [id])
  managed_locations  Location[]
  working_projects   Project[]  @relation("working_contact")
  deciding_projects  Project[]  @relation("decision_maker")
}

model Location {
  id                 Int     @id @default(autoincrement())
  client_id          Int
  name               String
  address            String
  manager_contact_id Int?

  client   Client   @relation(fields: [client_id], references: [id])
  manager  Contact? @relation(fields: [manager_contact_id], references: [id])
  projects Project[]
}

model ProjectType {
  id   Int    @id @default(autoincrement())
  name String @unique // user-managed; seeded: Vệ sinh, Thi công, Tháo dỡ

  projects Project[] // implicit m2m join table
}

model Project {
  id                        Int       @id @default(autoincrement())
  code                      String    @unique
  client_id                 Int
  location_id               Int
  working_contact_id        Int // defaults to location manager (app logic)
  decision_maker_contact_id Int // defaults to working contact (app logic)
  name                      String
  request_note              String? // stage 1: short "what they want done" from the first call
  referral_source           String? // stage 1: free text (giới thiệu, gọi lại, …) — not a managed list
  stage                     String    @default("request") // request | survey | quote | contract | paperwork | execution | acceptance | settlement | closed
  status                    String    @default("active") // active | on_hold | cancelled
  cancel_reason             String? // required when status = cancelled (DTO rule)
  follow_up_date            DateTime? @db.Date // on_hold jobs resurface
  appointment_at            DateTime? // stage 1; reschedule = update in place
  visit_date                DateTime? @db.Date // "Đã gặp khách" tap (1→2)
  survey_note               String? // stage 2; photos → Attachment(kind: survey)
  survey_items              Json? // stage 2: {name, quantity, unit, note}[] — scratch rows that prefill quote items; never queried across projects
  client_signed_date          DateTime? @db.Date // stage-4 gate 1
  execution_sub_status      String? // kickoff | hoarding | works
  start_date                DateTime? @db.Date
  est_duration_days         Int?
  actual_duration_days      Int? // manual = source of truth; timekeeping-derived computed at read time
  approaches                String? // free text until a structure emerges
  works_done_at             DateTime? // stage-6 exit button
  acceptance_sub_status     String? // request_sent | inspecting | rework | passed
  acceptance_passed_date    DateTime? @db.Date // stamped when acceptance_sub_status → passed
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  client          Client        @relation(fields: [client_id], references: [id])
  location        Location      @relation(fields: [location_id], references: [id])
  working_contact Contact       @relation("working_contact", fields: [working_contact_id], references: [id])
  decision_maker  Contact       @relation("decision_maker", fields: [decision_maker_contact_id], references: [id])
  types           ProjectType[] // 1..n tags (enforced ≥1 in DTO)

  quotes             Quote[]
  contracts          Contract[]
  paperwork_items    PaperworkItem[]
  settlements        Settlement[]
  bills              Bill[]
  payment_milestones PaymentMilestone[]
  assignments        Assignment[]
  timekeeping        TimekeepingRecord[]
  attachments        Attachment[]
  notes              ProjectNote[]
}

model Quote {
  id           Int       @id @default(autoincrement())
  project_id   Int
  version      Int // 1, 2, … — bargaining = new row; sent rows never edited
  status       String    @default("draft") // draft | waiting | deal | on_hold | rejected — latest version carries live status
  total_amount BigInt // VND
  vat_rate     Float     @default(0.08) // kept from v1 (printable A4 shows VAT)
  decided_date   DateTime? @db.Date
  note         String?

  project   Project        @relation(fields: [project_id], references: [id])
  items     QuoteItem[]
  send_logs QuoteSendLog[]

  @@unique([project_id, version])
}

model QuoteItem {
  id         Int     @id @default(autoincrement())
  quote_id   Int
  description String
  unit       String? // m², buổi, … (free text)
  quantity   Decimal
  unit_price BigInt // VND
  amount     BigInt // VND
  sort_order Int     @default(0)

  quote Quote @relation(fields: [quote_id], references: [id])
}

model QuoteSendLog {
  id            Int      @id @default(autoincrement())
  quote_id      Int
  channel       String // zalo | email | print
  sent_by       String // operator name; FK → User once ownership matters
  sent_at       DateTime @default(now())
  follow_up_ref String? // where to chase: Zalo chat, email address, print recipient

  quote Quote @relation(fields: [quote_id], references: [id])
}

model Contract {
  id         Int       @id @default(autoincrement())
  project_id Int // 0..n per project
  code       String    @unique
  status     String    @default("draft") // draft | signed
  signed_date  DateTime? @db.Date
  note       String?
  // printable-contract feature, kept from v1:
  template_id Int?
  body        String? // Lexical editorState JSON, opaque

  project  Project           @relation(fields: [project_id], references: [id])
  template ContractTemplate? @relation(fields: [template_id], references: [id])
}

model ContractTemplate {
  id           Int      @id @default(autoincrement())
  name         String
  doc_title    String
  body         String // Lexical editorState JSON, opaque
  header_style String   @default("letterhead") // letterhead | national
  is_active    Boolean  @default(true)

  contracts Contract[]
}

model PaperworkItem {
  id         Int    @id @default(autoincrement())
  project_id Int
  name       String // user-facing Vietnamese; seeded: Giấy phép thi công, PCCC, Danh sách nhân sự, Danh sách thiết bị
  status     String @default("preparing") // preparing | submitted | approved
  due_date   DateTime? @db.Date // permits have lead times; overdue is DERIVED (due_date < today && != approved), never stored
  note       String?

  project     Project      @relation(fields: [project_id], references: [id])
  attachments Attachment[]
}

model Settlement {
  id           Int       @id @default(autoincrement())
  project_id   Int // 0..n per project — settling happens in phases
  status       String    @default("draft") // draft | sent | signed
  total_amount BigInt    @default(0) // VND, server-computed from items; copied to the bill on sign
  signed_date  DateTime? @db.Date
  note         String?

  project Project          @relation(fields: [project_id], references: [id])
  bill    Bill?
  items   SettlementItem[]
}

model SettlementItem {
  id            Int     @id @default(autoincrement())
  settlement_id Int
  description   String
  unit          String? // m², buổi, … (free text)
  quantity      Decimal // adjusted to khối lượng thực tế (prefilled from quote items)
  unit_price    BigInt // VND
  amount        BigInt // VND, server-computed
  sort_order    Int     @default(0)

  settlement Settlement @relation(fields: [settlement_id], references: [id], onDelete: Cascade)
}

model Bill {
  id            Int       @id @default(autoincrement())
  project_id    Int // 0..n per project
  settlement_id Int?      @unique // signing the settlement flips its bill to official
  status        String    @default("draft") // draft | official | sent | paid — manual flips; future bank feed auto-flips paid
  total_amount  BigInt // VND
  sent_date       DateTime? @db.Date
  paid_date       DateTime? @db.Date

  project    Project            @relation(fields: [project_id], references: [id])
  settlement Settlement?        @relation(fields: [settlement_id], references: [id])
  milestones PaymentMilestone[]
}

model PaymentMilestone {
  id         Int       @id @default(autoincrement())
  project_id Int
  bill_id    Int? // null for the deposit (exists before any bill)
  type       String // deposit (= Cọc, stage 4) | progress | acceptance
  amount     BigInt // VND
  due_date   DateTime? @db.Date
  status     String    @default("not_due") // not_due | awaiting_payment | paid — overdue is DERIVED (due_date < today && != paid), never stored
  paid_date    DateTime? @db.Date

  project Project @relation(fields: [project_id], references: [id])
  bill    Bill?   @relation(fields: [bill_id], references: [id])
}

model CrewRole {
  id   Int    @id @default(autoincrement())
  name String @unique // user-managed; seeded: Thợ chính, Thợ phụ, Nhân viên vệ sinh, Giám sát, Lái xe

  default_for CrewMember[]
  assignments Assignment[]
}

model CrewMember {
  id              Int     @id @default(autoincrement())
  name            String
  phone           String? // Zalo — future mini-app identity, capture from day one
  employment_type String // permanent | day_hire
  default_role_id Int?
  status          String  @default("working") // working | on_leave | left
  note            String?
  created_at      DateTime @default(now())

  default_role CrewRole?           @relation(fields: [default_role_id], references: [id])
  assignments  Assignment[]
  timekeeping  TimekeepingRecord[]
}

model Assignment {
  id             Int       @id @default(autoincrement())
  project_id     Int
  crew_member_id Int
  role_id        Int? // overrides member's default role
  from_date      DateTime  @db.Date
  to_date        DateTime? @db.Date // null = open-ended
  // overlaps allowed — non-blocking warning in app, no DB constraint

  project     Project    @relation(fields: [project_id], references: [id])
  crew_member CrewMember @relation(fields: [crew_member_id], references: [id])
  role        CrewRole?  @relation(fields: [role_id], references: [id])
}

model TimekeepingRecord {
  id             Int      @id @default(autoincrement())
  crew_member_id Int
  project_id     Int
  work_date      DateTime @db.Date
  hours          Decimal // raw hours worked that day
  source         String // manual | zalo_app — manual is source of truth
  note           String?

  crew_member CrewMember @relation(fields: [crew_member_id], references: [id])
  project     Project    @relation(fields: [project_id], references: [id])

  // manual + zalo_app rows may coexist per day; conflicts resolved in UI
  @@unique([crew_member_id, project_id, work_date, source])
}

model Attachment {
  id                Int      @id @default(autoincrement())
  project_id        Int
  kind              String // survey | site_log | finish_image | signed_contract | acceptance_report | settlement | paperwork | other
  paperwork_item_id Int? // when kind = paperwork
  s3_key            String // S3 architecture TBD — shape stable regardless
  note              String?
  created_at        DateTime @default(now())

  project        Project        @relation(fields: [project_id], references: [id])
  paperwork_item PaperworkItem? @relation(fields: [paperwork_item_id], references: [id])
}

model ProjectNote {
  id         Int      @id @default(autoincrement())
  project_id Int
  tag        String? // e.g. kickoff, hoarding, rework
  body       String
  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id])
}
