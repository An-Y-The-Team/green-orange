# crm-api-nest — production drop-in for the Python crm-api. Its OWN database.
DATABASE_URL=postgresql://postgres:password@localhost:5432/crm_nest
PORT=8001

# local | oidc.  local = password grant (JWT below); oidc = verify Authentik tokens.
AUTH_MODE=local
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local demo user (created by `bun run seed`). crm-web auto-mints a token with
# these when AUTH_MODE=local — keep them matching CRM_DEV_USER/CRM_DEV_PASSWORD.
SEED_USER=admin
SEED_PASSWORD=admin

# OIDC (only when AUTH_MODE=oidc) — Authentik issuer + optional audience.
OIDC_ISSUER=
OIDC_AUDIENCE=

# CORS — crm-web origin(s), comma-separated.
CORS_ORIGINS=http://localhost:3002
