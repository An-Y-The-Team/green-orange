# Copy to .env and adjust. The defaults match the repo's docker-compose Postgres.

DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/crm

# Local JWT auth (teaching default). Generate a real secret: openssl rand -hex 32
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# "local" = username/password + local JWT.  "oidc" = validate Authentik tokens.
AUTH_MODE=local

# Authentik OIDC (only used when AUTH_MODE=oidc). Milestone — not yet implemented.
# OIDC_ISSUER=https://auth.example.com/application/o/crm/
# OIDC_AUDIENCE=your-authentik-client-id

# CORS — crm-web dev origin(s), comma-separated.
CORS_ORIGINS=http://localhost:3002
