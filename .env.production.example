# Copy to `.env.production` on the VPS and fill in. NEVER commit the real file.
#   cp .env.production.example .env.production

# ─── Container images (set by the deploy; pinned to a git SHA per release) ───
# The GitHub Actions deploy writes these for you. For a manual run, set them to
# the tag you want to deploy, e.g. ghcr.io/an-y-the-team/green-orange-web:v1.0.0
WEB_IMAGE=ghcr.io/an-y-the-team/green-orange-web:latest
CRM_WEB_IMAGE=ghcr.io/an-y-the-team/green-orange-crm-web:latest
CRM_API_IMAGE=ghcr.io/an-y-the-team/green-orange-crm-api:latest
# NOTE: the CMS is the pinned official `directus/directus` image set directly in
# docker-compose.prod.yml — there is no CMS_IMAGE here anymore.

# ─── PostgreSQL (containerized; not exposed to the host) ─────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
# Kept as `cms` for the legacy Payload DB (left intact for rollback). Directus
# uses its own `directus` DB (DIRECTUS_DB_DATABASE below), auto-created on a fresh
# volume; on an existing volume create it once by hand (see DEPLOY.md §9).
POSTGRES_DB=cms

# ─── Directus CMS ────────────────────────────────────────────────────────────
# Two independent random secrets. Generate each: openssl rand -hex 32
DIRECTUS_KEY=CHANGE_ME_openssl_rand_hex_32
DIRECTUS_SECRET=CHANGE_ME_openssl_rand_hex_32
# Directus's own database name (must be in POSTGRES_MULTIPLE_DATABASES).
DIRECTUS_DB_DATABASE=directus
# First admin, created on first boot by `directus bootstrap`.
DIRECTUS_ADMIN_EMAIL=admin@dichvuyan.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
# Public origin of the CMS (the browser loads assets from /assets/<id> here).
DIRECTUS_PUBLIC_URL=https://cms.dichvuyan.com

# Browser origins allowed to call the CMS API (comma-separated, no trailing /).
# Must include the public web domain so the contact form POST passes CORS.
CORS_ORIGINS=https://dichvuyan.com,https://www.dichvuyan.com

# ─── Web app ↔ Directus (server-only credentials) ────────────────────────────
# Read-only static token for SSR/ISR reads of published content (created in the
# Studio — see DEPLOY.md §9 / migration Phase 3).
DIRECTUS_STATIC_TOKEN=CHANGE_ME_directus_static_token
# Shared secret validated by the web app's /api/preview route for draft preview.
# Generate: openssl rand -hex 32
DIRECTUS_PREVIEW_SECRET=CHANGE_ME_openssl_rand_hex_32

# Public origin of the web app. Used for canonical URLs, Open Graph, sitemap.xml,
# robots.txt, and JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://dichvuyan.com

# ─── Caddy reverse proxy + automatic HTTPS ───────────────────────────────────
# Bare apex domain (Caddy also serves www.<SITE_DOMAIN>), CMS + Authentik subdomains.
SITE_DOMAIN=dichvuyan.com
CMS_DOMAIN=cms.dichvuyan.com
CRM_DOMAIN=quanly.dichvuyan.com
AUTH_DOMAIN=auth.dichvuyan.com
# Email for Let's Encrypt expiry notices (recommended; can be left blank).
ACME_EMAIL=you@dichvuyan.com

# ─── Authentik (identity provider for the CRM's OIDC login) ──────────────────
# Runs in this same stack against the `authentik` database in the postgres
# container (reuses POSTGRES_USER/PASSWORD above). Published at AUTH_DOMAIN.
# Pin to the current stable from https://goauthentik.io (releases).
AUTHENTIK_TAG=2025.10
# Django secret key. Generate a fresh one: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=CHANGE_ME_openssl_rand_base64_60
# First-boot bootstrap (applied only on a fresh `authentik` DB). Lets you log in
# as akadmin and register the prod `crm` app via scripts/setup-authentik-crm.py.
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_akadmin_password
# Generate: openssl rand -hex 32
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME_openssl_rand_hex_32
AUTHENTIK_BOOTSTRAP_EMAIL=admin@dichvuyan.com

# ─── CRM apps (crm-web dashboard + crm-api backend) ──────────────────────────
# crm-api is INTERNAL ONLY (no public port); crm-web is published at CRM_DOMAIN.
# crm-api uses its own `crm` database in the postgres container (reuses
# POSTGRES_USER/PASSWORD) — create that DB once by hand on an existing volume
# (see DEPLOY.md §6b). Both authenticate via the prod `crm` Authentik app.
#
# Auth.js session secret for crm-web. Generate: openssl rand -hex 32
CRM_AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
# OIDC client credentials printed by scripts/setup-authentik-crm.py (APP_SLUG=crm).
# The client id is shared: crm-web's provider id AND crm-api's token audience.
CRM_OIDC_CLIENT_ID=CHANGE_ME_authentik_crm_client_id
CRM_OIDC_CLIENT_SECRET=CHANGE_ME_authentik_crm_client_secret
