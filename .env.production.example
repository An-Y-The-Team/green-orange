# Copy to `.env.production` on the VPS and fill in. NEVER commit the real file.
#   cp .env.production.example .env.production

# ─── Container images (set by the deploy; pinned to a git SHA per release) ───
# The GitHub Actions deploy writes these for you. For a manual run, set them to
# the tag you want to deploy, e.g. ghcr.io/an-y-the-team/green-orange-web:v1.0.0
WEB_IMAGE=ghcr.io/an-y-the-team/green-orange-web:latest
CMS_IMAGE=ghcr.io/an-y-the-team/green-orange-cms:latest

# ─── PostgreSQL (containerized; not exposed to the host) ─────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=cms

# ─── Payload ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32   (use a NEW one for production)
PAYLOAD_SECRET=CHANGE_ME_openssl_rand_hex_32

# Browser origins allowed to call the CMS API (comma-separated, no trailing /).
# Must include the public web domain so the contact form POST passes CORS.
CORS_ORIGINS=https://dichvuyan.com,https://www.dichvuyan.com

# Public origin of the CMS itself. Used as Payload `serverURL` so uploaded media
# URLs are absolute (the web app reads them as plain strings) and admin/SEO links
# resolve. Should match the CMS subdomain above.
CMS_PUBLIC_URL=https://cms.dichvuyan.com

# Public origin of the web app. Used for canonical URLs, Open Graph, sitemap.xml,
# robots.txt, and JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://dichvuyan.com

# ─── Caddy reverse proxy + automatic HTTPS ───────────────────────────────────
# Bare apex domain (Caddy also serves www.<SITE_DOMAIN>), CMS + Authentik subdomains.
SITE_DOMAIN=dichvuyan.com
CMS_DOMAIN=cms.dichvuyan.com
AUTH_DOMAIN=auth.dichvuyan.com
# Email for Let's Encrypt expiry notices (recommended; can be left blank).
ACME_EMAIL=you@dichvuyan.com

# ─── Authentik (identity provider for the CRM's OIDC login) ──────────────────
# Runs in this same stack against the `authentik` database in the postgres
# container (reuses POSTGRES_USER/PASSWORD above). Published at AUTH_DOMAIN.
# Pin to the current stable from https://goauthentik.io (releases).
AUTHENTIK_TAG=2025.10
# Django secret key. Generate a fresh one: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=CHANGE_ME_openssl_rand_base64_60
# First-boot bootstrap (applied only on a fresh `authentik` DB). Lets you log in
# as akadmin and register the prod `crm` app via scripts/setup-authentik-crm.py.
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_akadmin_password
# Generate: openssl rand -hex 32
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME_openssl_rand_hex_32
AUTHENTIK_BOOTSTRAP_EMAIL=admin@dichvuyan.com
